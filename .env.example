# ──────────────────────────────────────────────
# MARS-1 Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── Required ──────────────────────────────────

OPENAI_API_KEY=your-api-key-here

# ── LLM Server ────────────────────────────────

# For self-hosted vLLM (HPC):
# OPENAI_BASE_URL=http://localhost:8000/v1

# For OpenAI API:
# OPENAI_BASE_URL=https://api.openai.com/v1

OPENAI_BASE_URL=http://localhost:8000/v1

# ── Models ────────────────────────────────────

# Default model used for all agents and baseline
OPENAI_ANSWER_MODEL=google/gemma-4-26B-A4B-it

# Model ablation: set these to different models to test
# strong vs fast agent performance. Both default to OPENAI_ANSWER_MODEL.
# FAST_AGENT_MODEL=google/gemma-4-26B-A4B-it
# STRONG_AGENT_MODEL=google/gemma-4-26B-A4B-it

# Judge model (use a different model family to avoid self-judge bias)
JUDGE_MODEL=gpt-4.1

# Per-role model overrides (rarely needed — experiment configs set these)
# BASELINE_MODEL=
# ORCHESTRATOR_MODEL=
# SEARCH_MODEL=
# SUMMARIZATION_MODEL=
# FACT_CHECK_MODEL=
# FINAL_SYNTHESIS_MODEL=

# ── LLM Parameters ───────────────────────────

OPENAI_ANSWER_MAX_OUTPUT_TOKENS=512
OPENAI_TIMEOUT_SECONDS=120

# ── Concurrency ───────────────────────────────

# Max parallel questions per experiment
QUESTION_CONCURRENCY=3

# Max parallel judge calls per experiment
JUDGE_CONCURRENCY=4

# ── Vector Store ──────────────────────────────

# Local JSON-based vector store (default for HPC)
VECTOR_STORE_PATH=data/vector_store.json

# ── Experiment Selection ──────────────────────

# Run all 24 experiments (default):
# EXPERIMENT_SLUGS=

# Run specific experiments only:
# EXPERIMENT_SLUGS=experiment01_architecture_control_top5,experiment09_all_small_top3

# ── Logging ───────────────────────────────────

LOG_LEVEL=INFO
